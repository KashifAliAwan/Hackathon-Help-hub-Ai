{
  "info": {
    "_postman_id": "f4bdb569-e926-48f2-986f-9de6f2ea4f72",
    "name": "Saylani Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Updated collection aligned with current backend routes: auth, community, requests, messages, notifications, and users. Use baseUrl for active environment. localBaseUrl is for development and deployedBaseUrl is for Vercel deployment."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const appEnv = (pm.environment.get('appEnv') || pm.collectionVariables.get('appEnv') || 'development').toLowerCase();",
          "const localBaseUrl = pm.environment.get('localBaseUrl') || pm.collectionVariables.get('localBaseUrl') || 'http://localhost:3080';",
          "const deployedBaseUrl = pm.environment.get('deployedBaseUrl') || pm.collectionVariables.get('deployedBaseUrl') || 'https://helplytics-backend.vercel.app';",
          "const activeBaseUrl = pm.environment.get('baseUrl') || pm.collectionVariables.get('baseUrl');",
          "const nextBaseUrl = appEnv === 'development' ? localBaseUrl : deployedBaseUrl;",
          "const isCustomBaseUrl = !!activeBaseUrl && activeBaseUrl !== localBaseUrl && activeBaseUrl !== deployedBaseUrl;",
          "if (!isCustomBaseUrl) {",
          "  if (pm.environment.has('baseUrl')) pm.environment.set('baseUrl', nextBaseUrl);",
          "  else pm.collectionVariables.set('baseUrl', nextBaseUrl);",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "appEnv",
      "value": "development"
    },
    {
      "key": "localBaseUrl",
      "value": "http://localhost:3080"
    },
    {
      "key": "deployedBaseUrl",
      "value": "https://helplytics-backend.vercel.app"
    },
    {
      "key": "baseUrl",
      "value": "http://localhost:3080"
